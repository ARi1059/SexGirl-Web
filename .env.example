# ───────── 数据库（Supabase 托管 Postgres）─────────
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ───────── Payload ─────────
# 生成随机密钥： openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# 站点地址（Payload 后台 / 邮件链接 / CORS）
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ───────── 对象存储（Supabase Storage，S3 兼容）─────────
# Supabase → Storage → Settings → S3 connection
S3_ENDPOINT=https://[PROJECT-REF].supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_BUCKET=media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
