# ───────── 数据库（Supabase 托管 Postgres）─────────
# 运行时（serverless）用「事务池」连接串：Supabase → Connect → Transaction pooler（端口 6543）。
# 形如：postgresql://postgres.[REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# 必须走池子，否则 Vercel 每次冷启动新建连接会打爆 Postgres max_connections。
DATABASE_URI=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# 迁移专用「直连」串（端口 5432，Supabase → Connect → Direct connection）。
# 事务池不适合多语句 DDL / 顾问锁；build:deploy 脚本会让 `payload migrate` 优先用它，
# 未设则回退 DATABASE_URI。仅迁移用，运行时不读。
# 形如：postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URI_DIRECT=

# 每个 serverless 实例的连接池上限（可选）。留空走 node-postgres 默认 10，配合事务池足够安全。
# ⚠ 不要设成 1：单次渲染里 Payload 可能需要并发连接，max=1 会死锁。要调优请用 ≥2。
DATABASE_POOL_MAX=

# ───────── Payload ─────────
# 生成随机密钥： openssl rand -base64 32
# 生产一次性生成后不要轮换——换了会让所有后台会话失效。
PAYLOAD_SECRET=replace-with-a-long-random-string

# 站点地址（Payload 后台 / 邮件链接 / CORS / CSRF）。
# ⚠ 不能带末尾斜杠或路径——CORS/CSRF 按精确字符串匹配浏览器 Origin 头（永不带斜杠），带了会静默失效。
# 生产填正式域名，如 https://your-app.vercel.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ───────── 对象存储（Supabase Storage，S3 兼容）─────────
# Supabase → Storage → Settings → S3 connection
S3_ENDPOINT=https://[PROJECT-REF].supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_BUCKET=media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
